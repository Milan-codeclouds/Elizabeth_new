<!-- Drawer -->
<div
  id="cart-drawer"
  class="fixed top-0 right-0 w-full max-w-md h-full bg-white shadow-xl transform translate-x-full transition-transform duration-300 z-50"
>
  <!-- Header -->
  <div class="flex justify-between items-center p-4 border-b">
    <h2 class="text-lg font-semibold">Your Cart</h2>
    <button id="cart-close">✕</button>
  </div>

  <!-- Items -->
  <div id="cart-items" class="p-4 space-y-4 overflow-y-auto h-[70%]"></div>

  <!-- Footer -->
  <div class="p-4 border-t">
    <div class="flex justify-between mb-4">
      <span>Subtotal</span>
      <span id="cart-subtotal">{{ cart.total_price | money }}</span>
    </div>
    <a href="/checkout" class="block text-center bg-black text-white py-3 rounded-lg">Checkout</a>
  </div>
</div>

<!-- Overlay -->
<div id="cart-overlay" class="fixed inset-0 bg-black opacity-70 hidden"></div>

<script>
  const drawer = document.getElementById('cart-drawer');
  const overlay = document.getElementById('cart-overlay');

  // Toggle Drawer
  function openCart() {
    drawer.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    loadCart();
  }

  function closeCart() {
    drawer.classList.add('translate-x-full');
    overlay.classList.add('hidden');
  }

  document.getElementById('cart-toggle').onclick = openCart;
  document.getElementById('cart-close').onclick = closeCart;
  overlay.onclick = closeCart;

  // Fetch Cart
  function loadCart() {
    fetch('/cart.js')
      .then((res) => res.json())
      .then((cart) => {
        const container = document.getElementById('cart-items');
        const subtotal = document.getElementById('cart-subtotal');
        const count = document.getElementById('cart-count');

        container.innerHTML = '';
        count.innerText = cart.item_count;
        subtotal.innerText = (cart.total_price / 100).toFixed(2);

        // ✅ EMPTY CART STATE
        if (cart.item_count === 0) {
          container.innerHTML = `
          <div class="h-full flex flex-col items-center justify-center text-center py-20">
            <div class="text-5xl mb-4">🛒</div>
            <h3 class="text-lg font-semibold mb-2">Your Cart is Empty</h3>
            <p class="text-gray-500 mb-6">Looks like you haven't added anything yet.</p>
            <a href="/collections/all" 
              class="bg-black text-white px-6 py-3 rounded-lg hover:bg-gray-800 transition">
              Start Shopping
            </a>
          </div>
        `;

          return; // ⛔ stop further rendering
        }

        // ✅ NORMAL CART ITEMS
        cart.items.forEach((item, index) => {
          container.innerHTML += `
          <div class="flex items-center gap-4 border rounded-lg p-3">
            <img src="${item.image}" class="w-16 h-16 object-cover rounded" />
            <div class="flex-1">
              <h3 class="text-sm font-medium">${item.product_title}</h3>
              <div class="flex items-center gap-2 mt-2">
                <input type="number" min="1" value="${item.quantity}" 
                  class="qty-input w-14 border rounded px-2 py-1" data-line="${index + 1}">
                <span>${(item.line_price / 100).toFixed(2)}</span>
              </div>
            </div>
            <button class="remove text-red-500" data-line="${index + 1}">✕</button>
          </div>
        `;
        });

        attachEvents();
      });
  }

  // Events
  function attachEvents() {
    document.querySelectorAll('.qty-input').forEach((input) => {
      input.addEventListener('change', function () {
        updateItem(this.dataset.line, this.value);
      });
    });

    document.querySelectorAll('.remove').forEach((btn) => {
      btn.addEventListener('click', function () {
        updateItem(this.dataset.line, 0);
      });
    });
  }

  // Update Item
  function updateItem(line, quantity) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: quantity }),
    })
      .then((res) => res.json())
      .then(() => loadCart());
  }
</script>
