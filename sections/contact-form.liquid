<div class="max-w-3xl mx-auto px-4 py-12">
  <!-- 📩 Heading -->
  <div class="text-center mb-10">
    <h2 class="text-3xl font-semibold text-gray-900">Contact Us</h2>
    <p class="text-gray-500 mt-2">We’d love to hear from you</p>
  </div>

  {% form 'contact', class: 'space-y-6' %}
    <!-- ✅ Success Message -->
    {% if form.posted_successfully? %}
      <div class="p-4 bg-green-100 text-green-700 rounded-lg">
        Thanks for contacting us! We'll get back to you soon.
      </div>
    {% endif %}

    <!-- ❌ Error Messages -->
    {% if form.errors %}
      <div class="p-4 bg-red-100 text-red-700 rounded-lg">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <!-- 👤 Name -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1"> Name </label>
      <input
        type="text"
        name="contact[name]"
        value="{{ form.name }}"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black"
        placeholder="Your name"
        required
      >
    </div>

    <!-- 📧 Email -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1"> Email </label>
      <input
        type="email"
        name="contact[email]"
        value="{{ form.email }}"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black"
        placeholder="you@example.com"
        required
      >
    </div>

    <!-- 📱 Phone (optional) -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1"> Phone (optional) </label>
      <input
        type="tel"
        name="contact[phone]"
        value="{{ form.phone }}"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black"
        placeholder="+91 9876543210"
      >
    </div>

    <!-- 💬 Message -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1"> Message </label>
      <textarea
        name="contact[body]"
        rows="5"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black"
        placeholder="Your message..."
        required
      >{{ form.body }}</textarea>
    </div>

    <!-- 🚀 Submit Button -->
    <div>
      <button
        type="submit"
        class="w-full bg-black text-white py-3 rounded-lg font-medium hover:bg-gray-800 transition"
      >
        Send Message
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Contact Form (Tailwind)",
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
