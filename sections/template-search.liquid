{% comment %}
  Shopify Search Template using Tailwind CSS
  File: templates/search.liquid
{% endcomment %}

<div class="max-w-6xl mx-auto px-4 py-8">
  <!-- Search Bar -->
  <form action="{{ routes.search_url }}" method="get" role="search" class="mb-8">
    <!-- IMPORTANT: Only search products -->
    <input type="hidden" name="type" value="product">

    <div class="flex items-center border rounded-lg overflow-hidden">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search for products..."
        class="w-full px-4 py-3 outline-none"
      >
      <button type="submit" class="bg-black text-white px-6 py-3 hover:bg-gray-800">Search</button>
    </div>
  </form>

  {% if search.performed %}
    <!-- Results Info -->
    <div class="mb-6">
      <h2 class="text-2xl font-semibold">Results for "{{ search.terms }}"</h2>
      <p class="text-gray-500 mt-1">{{ search.results_count }} results found</p>
    </div>

    {% if search.results_count > 0 %}
      <!-- ✅ PAGINATION START -->
      {% paginate search.results by 8 %}
        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'product-card', product: item %}
            {% endif %}
          {% endfor %}
        </div>

        <!-- Pagination -->
        <div class="mt-10">
          {% render 'pagination', paginate: paginate %}
        </div>
      {% endpaginate %}
      <!-- ✅ PAGINATION END -->

    {% else %}
      <!-- No Results -->
      <div class="text-center py-16">
        <h3 class="text-xl font-semibold">No results found</h3>
        <p class="text-gray-500 mt-2">Try different keywords</p>
      </div>
    {% endif %}

  {% else %}
    <!-- Empty State -->
    <div class="text-center py-16">
      <h3 class="text-xl font-semibold">Start searching</h3>
      <p class="text-gray-500 mt-2">Find your favorite products</p>
    </div>
  {% endif %}
</div>
