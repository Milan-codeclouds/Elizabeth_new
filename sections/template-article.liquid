<article class="max-w-3xl mx-auto px-4 py-10">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'article_title' %}
        <div class="flex flex-col gap-2.5 justify-center items-center">
          <a
            href="{{ blog.url }}"
            class="inline-flex text-center text-2xl font-bold text-gray-900 mb-6 hover:text-blue-600 transition"
          >
            {{ blog.title }}
          </a>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
            {{ article.title }}
          </h1>
        </div>

      {% when 'article_author' %}
        {% if section.settings.enable_author %}
          <p class="text-sm text-gray-500 mb-2">
            By <span class="font-medium text-gray-700">{{ article.author }}</span>
          </p>
        {% endif %}

      {% when 'article_published_date' %}
        {% if section.settings.enable_published_date %}
          <time
            datetime="{{ article.published_at | date: '%Y-%m-%d' }}"
            class="block text-xs text-gray-400 mb-6"
          >
            {{ article.published_at | date: '%B %d, %Y' }}
          </time>
        {% endif %}

      {% when 'article_featured_image' %}
        <div class="mb-8">
          {% if article.image %}
            <img
              width=""
              height=""
              src="{{ article.image | image_url: width: 800 }}"
              alt="{{ article.image.alt }}"
              class="w-full h-64 rounded-2xl shadow-md object-cover"
            >
          {% else %}
            <div class="w-full h-64 rounded-2xl shadow-md bg-gray-100 flex items-center justify-center">
              {{ 'image' | placeholder_svg_tag: 'w-32 h-32 text-gray-300' }}
            </div>
          {% endif %}
        </div>
        {{ article.image | json }}

      {% when 'article_content' %}
        <div class="prose prose-lg max-w-none text-gray-800 leading-relaxed">
          {{ article.content }}
        </div>

      {% else %}

    {% endcase %}
  {% endfor %}
</article>

{% if blog.comments_enabled? %}
  <div id="comments" class="my-8">
    {% if article.comments_count > 0 %}
      <div class="flex-1 items-center justify-center mx-auto max-w-4xl px-4">
        <h1 class="text-lg mb-4 font-medium">See what people are saying</h1>

        {% paginate article.comments by 5 %}
          {% for comment in article.comments %}
            <div class="flex-1 border my-4 px-4 py-2 sm:px-6 sm:py-4 leading-relaxed">
              <span class="comment-author">{{ comment.author }}</span>
              <span class="text-xs text-gray-400">{{ comment.created_at | date: format: 'default' }}</span>
              <p class="text-sm">{{ comment.content }}</p>
            </div>
          {% endfor %}

          {% if paginate.pages > 1 %}
            {{ paginate | default_pagination }}
          {% endif %}
        {% endpaginate %}
      </div>
    {% else %}
      There are no comments in this article
    {% endif %}
  </div>

  <div id="comment_form" class="mb-8">
    {% form 'new_comment', article %}
      <div class="flex-1 mx-auto items-center justify-center max-w-4xl px-4">
        <div class="px-1 md:flex mb-3">
          <div class="px-3 md:w-1/2">
            <label for="comment_author" class="text-gray-700 font-medium uppercase text-xs mb-2">Name</label>
            <input
              type="text"
              name="comment[author]"
              id="comment_author"
              class="w-full text-gray-700 border py-3 px-4 mb-3 focus:outline-none"
              placeholder="Jane Doe"
              required
            >
          </div>
          <div class="px-3 md:w-1/2">
            <label for="comment_email" class="text-gray-700 font-medium uppercase text-xs mb-2">Email</label>
            <input
              type="email"
              name="comment[email]"
              id="comment_email"
              class="w-full text-gray-700 border py-3 px-4 mb-3 focus:outline-none"
              placeholder="jane@doe.com"
              required
            >
          </div>
        </div>
        <div class="px-1 md:flex mb-3">
          <div class="md:w-full px-3">
            <label for="comment_content" class="text-gray-700 font-medium uppercase text-xs mb-2">Comment</label>
            <textarea
              class="w-full text-gray-700 border resize-none h-20 py-2 px-3 focus:outline-none"
              name="comment[body]"
              id="comment_content"
              required
            ></textarea>
          </div>
        </div>
        <div class="px-1 md:flex mb-3">
          <div class="md:w-full px-3">
            <input
              type="submit"
              value="Post Comment"
              class="w-full cursor-pointer px-4 py-2 border text-base font-medium text-white bg-gray-900 hover:bg-gray-500"
            >
          </div>
        </div>
      </div>
    {% endform %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Template Article",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_author",
      "default": true,
      "label": "Display Author Name"
    },
    {
      "type": "checkbox",
      "id": "enable_published_date",
      "default": true,
      "label": "Display Published Date"
    }
  ],
  "blocks": [
    {
      "type": "article_title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "article_author",
      "name": "Author",
      "limit": 1
    },
    {
      "type": "article_published_date",
      "name": "Published Date",
      "limit": 1
    },
    {
      "type": "article_featured_image",
      "name": "Thumbnail",
      "limit": 1
    },
    {
      "type": "article_content",
      "name": "Content",
      "limit": 1
    }
  ]
}
{% endschema %}
