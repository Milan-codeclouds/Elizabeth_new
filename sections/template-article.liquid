<article class="max-w-3xl mx-auto px-4 py-10">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'article_title' %}
        <div class="flex flex-col gap-2.5 justify-center items-center">
          <a
            href="{{ blog.url }}"
            class="inline-flex text-center text-2xl font-bold text-gray-900 mb-6 hover:text-blue-600 transition"
          >
            {{ blog.title }}
          </a>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
            {{ article.title }}
          </h1>
        </div>

      {% when 'article_author' %}
        {% if section.settings.enable_author %}
          <p class="text-sm text-gray-500 mb-2">
            By <span class="font-medium text-gray-700">{{ article.author }}</span>
          </p>
        {% endif %}

      {% when 'article_published_date' %}
        {% if section.settings.enable_published_date %}
          <time
            datetime="{{ article.published_at | date: '%Y-%m-%d' }}"
            class="block text-xs text-gray-400 mb-6"
          >
            {{ article.published_at | date: '%B %d, %Y' }}
          </time>
        {% endif %}

      {% when 'article_featured_image' %}
        <div class="mb-8">
          {% if article.image %}
            <img
              width=""
              height=""
              src="{{ article.image | image_url: width: 800 }}"
              alt="{{ article.image.alt }}"
              class="w-full h-64 rounded-2xl shadow-md object-cover"
            >
          {% else %}
            <div class="w-full h-64 rounded-2xl shadow-md bg-gray-100 flex items-center justify-center">
              {{ 'image' | placeholder_svg_tag: 'w-32 h-32 text-gray-300' }}
            </div>
          {% endif %}
        </div>
        {{ article.image | json }}

      {% when 'article_content' %}
        <div class="prose prose-lg max-w-none text-gray-800 leading-relaxed">
          {{ article.content }}
        </div>

      {% else %}

    {% endcase %}
  {% endfor %}
</article>

{% if blog.comments_enabled? %}
  <div id="comments" class="my-12">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-semibold text-gray-900 mb-6">💬 Comments ({{ article.comments_count }})</h2>

      {% if article.comments_count > 0 %}
        {% paginate article.comments by 5 %}
          <div class="space-y-6">
            {% for comment in article.comments %}
              <div class="flex gap-4 p-5 bg-white rounded-2xl shadow-sm border border-gray-100">
                <!-- Avatar -->
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center font-semibold text-gray-600">
                  {{ comment.author | slice: 0 }}
                </div>

                <!-- Content -->
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-1">
                    <h3 class="text-sm font-semibold text-gray-800">
                      {{ comment.author }}
                    </h3>
                    <span class="text-xs text-gray-400">
                      {{ comment.created_at | date: '%b %d, %Y' }}
                    </span>
                  </div>

                  <p class="text-sm text-gray-700 leading-relaxed">
                    {{ comment.content }}
                  </p>
                </div>
              </div>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="mt-6">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        {% endpaginate %}
      {% else %}
        <div class="text-center py-10 bg-gray-50 rounded-2xl border">
          <p class="text-gray-500">No comments yet. Be the first to share your thoughts ✨</p>
        </div>
      {% endif %}
    </div>
  </div>

  <div id="comment_form" class="mb-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">✍️ Leave a comment</h2>

      {% form 'new_comment', article %}
        {% if form.posted_successfully? %}
          <div class="mb-4 p-4 rounded-lg bg-green-50 border border-green-200 text-green-700">
            ✅ Your comment has been submitted successfully!
            {% if blog.moderated? %}
              <span class="block text-sm text-green-600 mt-1"> It will appear once approved. </span>
            {% endif %}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="mb-4 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700">
            ❌ Please fix the errors below:
            <ul class="mt-2 text-sm list-disc list-inside">
              {% for error in form.errors %}
                <li>{{ form.errors.messages[error] }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 space-y-4">
          <div class="grid md:grid-cols-2 gap-4">
            <input
              type="text"
              name="comment[author]"
              placeholder="Your name"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-gray-900 focus:outline-none"
              required
            >

            <input
              type="email"
              name="comment[email]"
              placeholder="Your email"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-gray-900 focus:outline-none"
              required
            >
          </div>

          <textarea
            name="comment[body]"
            rows="4"
            placeholder="Write your comment..."
            class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-gray-900 focus:outline-none resize-none"
            required
          ></textarea>

          <button
            type="submit"
            class="w-full md:w-auto px-6 py-3 bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-700 transition"
          >
            Post Comment
          </button>
        </div>
      {% endform %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Template Article",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_author",
      "default": true,
      "label": "Display Author Name"
    },
    {
      "type": "checkbox",
      "id": "enable_published_date",
      "default": true,
      "label": "Display Published Date"
    }
  ],
  "blocks": [
    {
      "type": "article_title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "article_author",
      "name": "Author",
      "limit": 1
    },
    {
      "type": "article_published_date",
      "name": "Published Date",
      "limit": 1
    },
    {
      "type": "article_featured_image",
      "name": "Thumbnail",
      "limit": 1
    },
    {
      "type": "article_content",
      "name": "Content",
      "limit": 1
    }
  ]
}
{% endschema %}
